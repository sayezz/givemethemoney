# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your actual secrets.

# REQUIRED: secret used to sign JWT auth tokens. The backend refuses to start
# if this is unset. Generate a strong random value, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change_me_generate_a_long_random_value

# REQUIRED: PostgreSQL password. The database and backend refuse to start if unset.
DB_PASSWORD=change_me_strong_db_password
# Optional DB overrides (defaults: tracker_user / investment_tracker)
DB_USER=tracker_user
DB_NAME=investment_tracker

# Financial Modeling Prep (FMP) — https://financialmodelingprep.com/
# Free tier: 250 requests/day
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage — https://www.alphavantage.co/
# Free tier: 25 requests/day — disable auto-update in the dashboard to conserve quota
AV_API_KEY=your_alphavantage_api_key_here

# SMTP for trailing stop email notifications (sent once per position when TS is reached)
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
#   SMTP_URL=smtps://smtp.gmail.com:465
# Office365 / Outlook:
#   SMTP_URL=smtp://smtp.office365.com:587
SMTP_URL=smtps://smtp.example.com:465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# Notification is sent to each user's own login email — no fixed NOTIFY_EMAIL needed
